---
import { href } from '../lib/site';

interface Props {
  /** What this page's role will be once authored. Describes intent — never asserts theory. */
  role: string;
  /** Optional extra note (e.g. illustrative/no-glyph guidance). */
  note?: string;
}
const { role, note } = Astro.props;
---

<div class="card border-dashed border-[var(--color-rule-strong)] p-6 sm:p-8 bg-[var(--color-surface-alt)]">
  <p class="eyebrow mb-3">Planned — not yet written</p>
  <p class="text-[1.05rem] leading-relaxed text-[var(--color-ink)]">{role}</p>
  {note && <p class="ui text-sm leading-relaxed text-[var(--color-muted)] mt-3">{note}</p>}
  <p class="ui text-sm leading-relaxed text-[var(--color-faint)] mt-5">
    This is an honest placeholder: the page exists in the navigation so the structure is visible,
    but its content has not been authored. Drop a Markdown file into <span class="mono">content/</span>
    (see the <a href={href('/note-to-researchers')}>Note to Researchers</a>) and replace this stub.
  </p>
</div>
