---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ClaimPage from '../../components/ClaimPage.astro';
import { getClaims, getPredictions, type Claim } from '../../lib/claims';

export async function getStaticPaths() {
  const all = await getClaims();
  return getPredictions(all).map((claim) => ({
    params: { slug: claim.data.slug },
    props: { claim, all },
  }));
}

interface Props {
  claim: Claim;
  all: Claim[];
}
const { claim, all } = Astro.props;
---

<BaseLayout title={claim.data.title} narrow description={claim.data.summary}>
  <ClaimPage claim={claim} all={all} />
</BaseLayout>
