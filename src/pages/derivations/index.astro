---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ClaimCard from '../../components/ClaimCard.astro';
import { href } from '../../lib/site';
import { getClaims, getDerivationUnits, resolveDeps } from '../../lib/claims';

const all = await getClaims();
const units = getDerivationUnits(all);
---

<BaseLayout title="Derivations" narrow description="The workbench — every derived and provisional result as a self-contained research target, dependency-ordered.">
  <header class="mb-8">
    <p class="eyebrow mb-2">Framework · Derivations</p>
    <h1 class="font-serif text-3xl text-[var(--color-ink)]">Derivations</h1>
    <p class="ui text-[var(--color-muted)] mt-2 leading-relaxed">
      Each entry is a self-contained research target: a result that follows from the foundations, with
      its status glyph telling you at a glance what still needs work. The list is dependency-ordered, so
      it reads as a progression. Pick one and it's a discrete unit of work — firm up a provisional
      result, derive a corollary, find a connecting result. For where each sits in the whole argument,
      see the <a href={href('/derivation-chain')}>derivation chain</a>.
    </p>
  </header>

  {units.length === 0 ? (
    <p class="ui text-sm text-[var(--color-faint)]">No derivations authored yet.</p>
  ) : (
    <div class="flex flex-col gap-4">
      {units.map((c) => <ClaimCard claim={c} restsOn={resolveDeps(c, all)} />)}
    </div>
  )}
</BaseLayout>
