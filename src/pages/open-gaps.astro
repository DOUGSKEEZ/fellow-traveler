---
import BaseLayout from '../layouts/BaseLayout.astro';
import ClaimCard from '../components/ClaimCard.astro';
import { href } from '../lib/site';
import { getClaims } from '../lib/claims';

const all = await getClaims();
// The unfinished or set-aside work, by rigor status: drafts (○), stubs (·), and non-viable (✗)
// claims, plus anything explicitly filed in the open-gap layer.
const gaps = all.filter(
  (c) => c.data.layer === 'open-gap' || ['draft', 'stub', 'non-viable'].includes(c.data.status),
);
const provisional = all.filter((c) => c.data.status === 'provisional');
---

<BaseLayout title="Open Gaps" description="Every acknowledged unknown, collected automatically, plus the provisional results that carry live caveats.">
  <header class="mb-8">
    <p class="eyebrow mb-2">The honesty page</p>
    <h1 class="font-serif text-3xl text-[var(--color-ink)]">Open Gaps</h1>
    <p class="ui text-[var(--color-muted)] mt-2 max-w-2xl leading-relaxed">
      What the framework does <em>not</em> yet have. Collected automatically: anything marked
      <span class="mono text-sm">draft</span> (○), <span class="mono text-sm">stub</span> (·), or
      <span class="mono text-sm">non-viable</span> (✗) appears here, and the
      <span class="mono text-sm">provisional</span> results — true-but-not-yet-rigorous — are listed
      below with their caveats intact. A gap marked openly is worth more than a gap papered over.
    </p>
  </header>

  <section class="mb-12">
    <div class="flex items-center gap-3 border-b border-[var(--color-rule)] pb-2 mb-5">
      <span class="glyph-draft text-2xl leading-none">○</span>
      <h2 class="font-serif text-2xl text-[var(--color-ink)]">Unfinished &amp; set aside</h2>
    </div>
    {gaps.length === 0 ? (
      <div class="card p-6 ui text-sm text-[var(--color-muted)] leading-relaxed">
        <p>
          No file currently carries <span class="mono">draft</span>, <span class="mono">stub</span>, or
          <span class="mono">non-viable</span> status. The acknowledged unknowns — the confirm-strong /
          disconfirm-weak asymmetry of the demarcation falsifier, and the causal direction question
          (does the pathway generate the trait, or the trait the pathway?) — are named inside the
          claims that raise them, but have not yet been promoted to standalone files.
        </p>
        <p class="mt-3">
          When one is, it lands here automatically. See, in the meantime, the asymmetry caveat in
          <a href={href('/demarcation/demarcation-principle')}>The Demarcation Principle</a>.
        </p>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {gaps.map((c) => <ClaimCard claim={c} showLayer />)}
      </div>
    )}
  </section>

  <section>
    <div class="flex items-center gap-3 border-b border-[var(--color-rule)] pb-2 mb-5">
      <span class="glyph-provisional text-2xl leading-none">◐</span>
      <h2 class="font-serif text-2xl text-[var(--color-ink)]">Provisional — carries caveats</h2>
    </div>
    <p class="ui text-sm text-[var(--color-muted)] mb-5 max-w-2xl">
      Plausible and motivated, but not yet rigorous. Each links to the file where its specific caveat is
      stated in full.
    </p>
    {provisional.length === 0 ? (
      <p class="ui text-sm text-[var(--color-faint)]">Nothing provisional at the moment.</p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {provisional.map((c) => <ClaimCard claim={c} showLayer />)}
      </div>
    )}
  </section>
</BaseLayout>
