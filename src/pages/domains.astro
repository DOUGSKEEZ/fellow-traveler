---
import BaseLayout from '../layouts/BaseLayout.astro';
import ClaimSection from '../components/ClaimSection.astro';
import Placeholder from '../components/Placeholder.astro';
import { getClaims } from '../lib/claims';

const all = await getClaims();
// Forward-compatible: if application-layer claims are ever authored they compose here; until then
// this is an honest stub landing page.
const entries = all.filter((c) => c.data.layer === 'application').sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Domains" narrow description="Applications of the framework to specific domains — hiring, dating, VC, medical diagnosis, and the Fermi paradox. (Planned section.)">
  <header class="mb-8">
    <p class="eyebrow mb-2">Applications</p>
    <h1 class="font-serif text-3xl text-[var(--color-ink)]">Domains</h1>
  </header>

  {entries.length === 0 ? (
    <Placeholder
      role="This section will apply the framework to specific domains — hiring, dating, venture capital, medical diagnosis, and the Fermi paradox (Great Filters as collider bottlenecks)."
      note="Each application must clear the demarcation test before it counts as evidence rather than anecdote — a real pathway predicts further, unsung cases, not just the famous one we started from."
    />
  ) : (
    <div class="flex flex-col gap-12">
      {entries.map((c, i) => (
        <>
          {i > 0 && <hr class="border-[var(--color-rule)]" />}
          <ClaimSection claim={c} />
        </>
      ))}
    </div>
  )}
</BaseLayout>
